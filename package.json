{
  "name": "store-shots",
  "version": "0.1.0",
  "description": "Generate App Store screenshots where the live preview is the exact final output.",
  "keywords": [
    "app-store",
    "app-store-connect",
    "bun",
    "headless-chrome",
    "ios",
    "screenshots"
  ],
  "homepage": "https://github.com/tzwzx/store-shots#readme",
  "bugs": "https://github.com/tzwzx/store-shots/issues",
  "license": "MIT",
  "author": "Naoto Tazawa (https://github.com/tzwzx)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tzwzx/store-shots.git"
  },
  "bin": {
    "store-shots": "./src/cli.ts"
  },
  "files": [
    "scaffold",
    "src"
  ],
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "oxfmt --check && oxlint",
    "fix": "oxfmt && oxlint --fix",
    "typecheck": "tsc --noEmit",
    "spellcheck": "bunx cspell \"**\"",
    "fallow": "fallow",
    "test": "bun test",
    "syncpack:lint": "syncpack lint",
    "syncpack:fix": "syncpack fix",
    "codesweep:check": "codesweep check",
    "codesweep:fix": "codesweep fix"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.10.6",
    "@types/bun": "1.3.14",
    "@tzwzx/codesweep": "1.1.0",
    "fallow": "3.3.0",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "syncpack": "15.3.2",
    "typescript": "7.0.2",
    "ultracite": "7.9.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
